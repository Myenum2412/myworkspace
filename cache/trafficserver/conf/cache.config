# Apache Traffic Server Cache Rules — MyWorkSpace CDN
# Layer 6: Reverse Proxy / CDN Cache

# ── Static assets: immutable, cache for 365 days ──
regex .*\.(js|css|map)$
  ttl=31536000
  cache-responses=yes

regex .*\.(jpg|jpeg|png|gif|webp|avif|svg|ico)$
  ttl=31536000
  cache-responses=yes

regex .*\.(woff2?|ttf|eot|otf)$
  ttl=31536000
  cache-responses=yes

regex .*\.pdf$
  ttl=31536000
  cache-responses=yes

# ── Next.js static build output ──
regex /_next/static/.*
  ttl=31536000
  cache-responses=yes

# ── Uploaded files: cache for 7 days ──
regex /uploads/.*
  ttl=604800
  cache-responses=yes

# ── Banners: cache for 1 day ──
regex /banners/.*
  ttl=86400
  cache-responses=yes

# ── API responses: cache only GET with shorter TTL ──
regex /api/(dashboard|search|settings) ^l
  ttl=120
  cache-responses=yes

# ── Do not cache API mutations ──
regex /api/.*
  method=POST|PUT|PATCH|DELETE|CONNECT|OPTIONS|TRACE
  cache-responses=no

# ── Do not cache HTML pages (handled by Varnish) ──
regex .*\.html?$
  cache-responses=no

# ── Cache TUS upload requests for 24h (tiny files) ──
regex /api/files-tus/.*
  ttl=86400
  cache-responses=yes

# ── Default: don't cache ──
regex .*
  ttl=0
  cache-responses=no