# Apache Traffic Server Cache Rules - MyWorkSpace CDN

# Cache static assets for 365 days
regex .*\.(jpg|jpeg|png|gif|webp|avif|svg|ico|css|js|woff2?|ttf|eot|otf)$
  ttl=31536000
  cache-responses=yes

# Cache Next.js static build output
regex /_next/static/.*
  ttl=31536000
  cache-responses=yes

# Cache uploaded files for 7 days
regex /uploads/.*
  ttl=604800
  cache-responses=yes

# Cache banners for 1 day
regex /banners/.*
  ttl=86400
  cache-responses=yes

# Do not cache API responses
regex /api/.*
  cache-responses=no

# Do not cache HTML pages (handled by Varnish)
regex .*\.html?$
  cache-responses=no

# Default: don't cache
regex .*
  ttl=0
  cache-responses=no
