{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "radix-nova",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "config": "",
    "css": "app/globals.css",
    "baseColor": "neutral",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "lucide",
  "rtl": false,
  "menuColor": "default",
  "menuAccent": "subtle",
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  },
  "registries": {
    "@evilcharts": "https://evilcharts.com/r/{name}.json",
    "@reui": "https://reui.io/r/{style}/{name}.json",
    "@kokonutui": "https://kokonutui.com/r/{name}.json",
    "@smoothui": "https://smoothui.dev/r/{name}.json",
    "@bklit": "https://ui.bklit.com/r/{name}.json",
    "@elements": "https://www.tryelements.dev/r/{name}.json",
    "@7ovr": "https://7ovr.com/r/{name}.json",
    "@tailark": "https://tailark.com/r/{name}.json",
    "@motion-primitives": "https://motion-primitives.com/r/{name}.json"
  }
}
