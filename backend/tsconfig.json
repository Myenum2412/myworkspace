{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {}  // Using relative imports; tsx doesn't support tsconfig paths natively
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
