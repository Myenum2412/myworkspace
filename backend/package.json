{
  "name": "myworkspace-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "fuser -k 4000/tcp 2>/dev/null; tsx watch src/index.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
    "db:seed": "tsx src/lib/db/seed.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --forceExit --detectOpenHandles",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --watch --forceExit"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.14.1",
    "multer": "^2.2.0",
    "uuid": "^14.0.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "mongodb-memory-server": "^11.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "@types/jest": "^30.4.1",
    "@types/supertest": "^6.0.3",
    "jest": "^30.4.1",
    "supertest": "^7.1.0",
    "ts-jest": "^30.4.1"
  }
}
