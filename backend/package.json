{
  "name": "myworkspace-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "fuser -k 4000/tcp 2>/dev/null; tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "fuser -k 4000/tcp 2>/dev/null; tsx --env-file=.env src/index.ts",
    "db:seed": "tsx --env-file=.env src/lib/db/seed.ts",
    "db:seed-admin": "tsx --env-file=.env src/lib/db/seed-admin.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --runInBand"
  },
  "dependencies": {
    "@agendajs/mongo-backend": "^4.0.2",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@panva/hkdf": "^1.2.1",
    "agenda": "^6.2.5",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.2.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.14.1",
    "multer": "^2.2.0",
    "node-cache": "^5.1.2",
    "resend": "^2.0.0",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/express-rate-limit": "^2.9.9",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.2.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
