{
  "name": "myworkspace-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "fuser -k 4000/tcp 2>/dev/null; tsx watch --env-file=.env src/index.ts",
    "build": "tsc && cp src/config/*.conf src/config/*.csv dist/config/ 2>/dev/null; true",
    "start": "AWS_SDK_JS_SUPPRESS_MAINTENANCE_MODE_MESSAGE=1 node --env-file=.env --disable-warning=DEP0169 dist/index.js",
    "db:seed": "tsx --env-file=.env src/lib/db/seed.ts",
    "db:seed-admin": "tsx --env-file=.env src/lib/db/seed-admin.ts",
    "db:migrate-plans": "tsx --env-file=.env src/scripts/migrate-plans.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --runInBand",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns='tests/backend/unit' --runInBand",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns='tests/backend/integration' --runInBand",
    "test:security": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns='tests/backend/security' --runInBand",
    "test:socket": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns='tests/backend/socket' --runInBand",
    "test:queue": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns='tests/backend/queue' --runInBand",
    "test:payment": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns='tests/backend/payment' --runInBand --passWithNoTests",
    "test:cache": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns='tests/backend/cache' --runInBand",
    "test:concurrency": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns='tests/backend/concurrency' --runInBand",
    "test:data-integrity": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns='tests/backend/data-integrity' --runInBand",
    "test:resilience": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns='tests/backend/resilience' --runInBand",
    "test:all": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --testPathPatterns='tests/backend/(unit|integration|security|socket|queue|payment|cache|concurrency|data-integrity|resilience|search|streaming|ttl-cleanup|multi-instance|build-deploy|email-webhook-automation)'",
    "test:load": "k6 run tests/backend/performance/load-test.js",
    "test:soak": "k6 run tests/backend/performance/soak-test.js"
  },
  "dependencies": {
    "@agendajs/mongo-backend": "^4.0.2",
    "@anthropic-ai/sdk": "^0.111.0",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-prometheus": "^0.219.0",
    "@panva/hkdf": "^1.2.1",
    "@sentry/node": "^8.54.0",
    "agenda": "^6.2.5",
    "amqplib": "^2.0.1",
    "bcryptjs": "^3.0.3",
    "casbin": "^5.51.1",
    "casbin-mongoose-adapter": "^5.6.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.0",
    "file-type": "^20.4.1",
    "geoip-lite": "^1.4.10",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.14.1",
    "multer": "^2.2.0",
    "node-cache": "^5.1.2",
    "nodemailer": "^9.0.3",
    "openai": "^6.47.0",
    "otpauth": "^9.3.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^5.0.0",
    "resend": "^6.17.1",
    "sharp": "^0.35.3",
    "socket.io": "^4.8.3",
    "tus-node-server": "^0.9.0",
    "uuid": "^14.0.0",
    "web-push": "^3.6.7",
    "whatsapp-web.js": "^1.34.7",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/express-rate-limit": "^2.9.9",
    "@types/geoip-lite": "^1.4.4",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.2.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
